# frontend/.env.example
# Copy to .env.local for local development
# Set same vars in Vercel dashboard for production

# Backend URL
# Local: http://localhost:8000
# Production: https://ai-assignment-backend.onrender.com
NEXT_PUBLIC_API_URL=http://localhost:8000

# Razorpay Key ID (public — safe to expose in frontend)
# Get from: dashboard.razorpay.com → Settings → API Keys
NEXT_PUBLIC_RAZORPAY_KEY=rzp_test_xxxxxxxxxxxx
