# backend/.env.example
# Copy this file to .env and fill in your values
# NEVER commit .env to git — add it to .gitignore

# ─── Database (Neon PostgreSQL) ──────────────────────────────────────────────
# Get from: https://neon.tech → your project → Connect → Connection string
# IMPORTANT: Change postgresql:// to postgresql+asyncpg:// for async Python
DATABASE_URL=postgresql+asyncpg://user:password@ep-xxx-xxx.neon.tech/neondb?sslmode=require

# ─── Redis / Celery (Upstash — free tier) ────────────────────────────────────
# Get from: https://upstash.com → your database → Details tab
# IMPORTANT: Use rediss:// (double s = SSL) — required by Upstash
REDIS_URL=rediss://default:your_password@your-region.upstash.io:6379
CELERY_BROKER_URL=rediss://default:your_password@your-region.upstash.io:6379
CELERY_RESULT_BACKEND=rediss://default:your_password@your-region.upstash.io:6379

# ─── AI (Groq — free) ────────────────────────────────────────────────────────
# Get from: https://console.groq.com → API Keys → Create Key
# Key starts with: gsk_
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: OpenAI as fallback if Groq rate limits hit
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ─── Authentication ───────────────────────────────────────────────────────────
# Generate random string: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace-this-with-64-random-characters
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── File Storage (Cloudinary) ────────────────────────────────────────────────
# Get all three from: https://cloudinary.com → Sign up free → Dashboard
# Free tier: 25 GB storage + 25 GB bandwidth/month — no credit card needed
#
# How to find these values:
#   1. Go to cloudinary.com and sign up (free)
#   2. After login you land on the Dashboard
#   3. Under "API Keys" section you see all three values
#   4. Copy each one below
#
CLOUDINARY_CLOUD_NAME=your_cloud_name        # e.g. dxyz123abc
CLOUDINARY_API_KEY=your_api_key              # e.g. 123456789012345
CLOUDINARY_API_SECRET=your_api_secret        # e.g. AbCdEfGhIjKlMnOpQrStUvWxYz1234

# ─── Payments (Razorpay) ──────────────────────────────────────────────────────
# Get from: https://dashboard.razorpay.com → Settings → API Keys
# Test keys start with: rzp_test_  (no real money, use for development)
# Live keys start with: rzp_live_  (real money, needs KYC approval)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx

# ─── App Settings ─────────────────────────────────────────────────────────────
# Update FRONTEND_URL and ALLOWED_ORIGINS after you deploy frontend to Vercel
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=["http://localhost:3000"]

DEBUG=false
FREE_DAILY_LIMIT=3
